---
import PageIntro from './PageIntro.astro';

interface ArticleMeta {
	category: string;
	title: string;
	date: string;
	readingMinutes: number;
	tags: string[];
	lead: string[];
}

interface Props {
	article: ArticleMeta;
}

const { article } = Astro.props;
const readingTimeLabel = `だいたい${article.readingMinutes}分くらい`;
const meta = [
	{ icon: 'calendar' as const, text: article.date },
	{ icon: 'clock' as const, text: readingTimeLabel },
	{ icon: 'none' as const, text: article.tags.map((tag) => `#${tag}`).join('　') },
];
---

<PageIntro
	badgeLabel={article.category}
	title={article.title}
	metaLabel="記事情報"
	meta={meta}
	lead={article.lead}
	style="--page-intro-margin-block-end: clamp(3rem, 7vw, 5rem); --page-intro-mobile-margin-block-end: 2.5rem"
/>
