---
import HeroSection from '../components/HeroSection.astro';
import Layout from '../layouts/Layout.astro';
import MainSection from '../components/MainSection.astro';
import { getCollection } from 'astro:content';
import { extractExcerpt, formatDate } from '../lib/posts';

const posts = await getCollection('posts');
const sortedPosts = posts.toSorted((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const articles = sortedPosts.map((post) => ({
	title: post.data.title.replaceAll('\n', ' '),
	category: post.data.category,
	date: formatDate(post.data.date),
	readingTime: `だいたい${post.data.readingMinutes}分くらい`,
	excerpt: extractExcerpt(post.body ?? ''),
	tags: post.data.tags,
	href: `/posts/${post.id}`,
}));
---

<Layout title="sleepy-turtle">
	<div class="hero-section-container">
		<HeroSection />
	</div>
	<MainSection articles={articles} />
</Layout>

<style>
	.hero-section-container {
		margin-block-end: 46px;
		overflow: visible;
	}
</style>
