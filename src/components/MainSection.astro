---
import ArticleCard from './ArticleCard.astro';

interface Article {
	title: string;
	category: string;
	date: string;
	readingTime: string;
	excerpt: string;
	tags: string[];
	href: string;
}

interface Props {
	articles: Article[];
}

const { articles } = Astro.props;
const [featuredArticle, ...otherArticles] = articles;
---

<section class="main-section" aria-labelledby="recent-title">
	<div class="section-heading">
		<h2 id="recent-title">最近の足あと</h2>
	</div>

	<div class="article-grid">
		<div class="featured-slot">
			{featuredArticle && <ArticleCard article={featuredArticle} featured />}
		</div>
		<div class="side-list">
			{otherArticles.map((article) => <ArticleCard article={article} />)}
		</div>
	</div>
</section>

<style>
	.main-section {
		position: relative;
		padding-block: 1.25rem 4rem;
	}

	.main-section::before {
		position: absolute;
		inset-block: 1.25rem 0;
		inset-inline-start: 0;
		width: 2px;
		background: var(--accent-primary);
		content: '';
	}

	.section-heading {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-block-end: 2rem;
		padding-inline-start: 1.8rem;
	}

	.section-heading::after {
		height: 1px;
		background: color-mix(in srgb, var(--border) 25%, transparent);
		content: '';
	}

	.section-heading::before {
		width: 3rem;
		margin-inline-start: -1.8rem;
	}

	.section-heading::after {
		flex: 1;
	}

	h2 {
		margin: 0;
		color: var(--text-primary);
		font-size: var(--text-2xl);
		font-family: var(--font-heading-1);
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1;
	}

	.article-grid {
		--article-card-row-min: 17.5rem;
		--article-card-gap: 1.75rem;
		display: grid;
		width: 100%;
		min-width: 0;
		grid-template-columns: minmax(22rem, 1.05fr) minmax(32rem, 1.35fr);
		align-items: stretch;
		column-gap: clamp(2rem, 4vw, 3.25rem);
		padding-inline-start: clamp(1.75rem, 4vw, 3.75rem);
	}

	.featured-slot {
		display: flex;
		min-width: 0;
		min-height: 0;
	}

	.featured-slot :global(.article-card.featured) {
		flex: 1;
		width: 100%;
		min-height: 0;
	}

	.side-list {
		display: grid;
		min-width: 0;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		grid-template-rows: repeat(2, minmax(var(--article-card-row-min), auto));
		gap: var(--article-card-gap);
	}

	@media (min-width: 1101px) {
		.article-grid {
			--article-grid-block-height: calc(
				2 * var(--article-card-row-min) + var(--article-card-gap)
			);
		}

		.featured-slot,
		.side-list {
			height: var(--article-grid-block-height);
		}

		.side-list {
			grid-template-rows: repeat(2, minmax(0, 1fr));
		}

		.side-list :global(.article-card) {
			min-height: 0;
		}
	}

	@media (max-width: 1100px) {
		.article-grid {
			grid-template-columns: 1fr;
			row-gap: var(--article-card-gap);
		}

		.featured-slot :global(.article-card.featured) {
			flex: none;
			width: 100%;
		}

		.side-list {
			grid-template-rows: none;
			grid-auto-rows: minmax(var(--article-card-row-min), auto);
		}
	}

	@media (max-width: 720px) {
		.main-section {
			padding-block: 0.75rem 3rem;
		}

		.main-section::before {
			inset-inline-start: 0.25rem;
		}

		.section-heading {
			gap: 1rem;
			margin-block-end: 1.25rem;
			padding-inline-start: 1.35rem;
		}

		.article-grid {
			--article-card-gap: 1.15rem;
			padding-inline-start: 1rem;
		}

		.side-list {
			grid-template-columns: 1fr;
		}

	}
</style>
