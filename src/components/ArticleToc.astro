---
import Leaf from '@lucide/astro/icons/leaf';

interface TocItem {
	id: string;
	title: string;
	depth: number;
}

interface Props {
	items: TocItem[];
}

const { items } = Astro.props;
---

<aside class="article-toc" aria-labelledby="toc-title">
	<h2 id="toc-title">
		On this page
		<Leaf class="toc-title-icon" aria-hidden="true" />
	</h2>
	<nav aria-label="記事内目次">
		<ul>
			{
				items.map((item) => (
					<li style={`--toc-depth: ${Math.max(item.depth - 2, 0)}`}>
						<a href={`#${item.id}`} data-toc-link>{item.title}</a>
					</li>
				))
			}
		</ul>
	</nav>
</aside>

<style>
	.article-toc {
		position: sticky;
		top: 2rem;
		align-self: start;
		padding: 1.35rem 1.35rem 1.45rem;
		border: 1px solid color-mix(in srgb, var(--color-primitive-secondary-60) 20%, transparent);
		border-radius: 0.18rem;
		background: color-mix(in srgb, var(--color-primitive-secondary-20) 82%, #fff9db);
		color: var(--text-secondary);
		box-shadow:
			0.25rem 0.45rem 0.45rem color-mix(in srgb, var(--border) 22%, transparent),
			inset 0 0 1.8rem color-mix(in srgb, #ffffff 34%, transparent);
		transform: rotate(-0.7deg);
	}

	.article-toc::before {
		position: absolute;
		inset-block-start: -1.1rem;
		inset-inline-end: 1.05rem;
		width: 0.58rem;
		height: 2.35rem;
		border: 0.18rem solid var(--text-secondary);
		border-block-end-color: transparent;
		border-radius: 999px 999px 0.35rem 0.35rem;
		box-shadow: inset 0.18rem 0 0 color-mix(in srgb, var(--text-secondary) 75%, transparent);
		content: '';
		transform: rotate(-3deg);
	}

	h2 {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin: 0 0 1.2rem;
		color: var(--text-secondary);
		font-family: var(--font-quote-text);
		font-size: var(--text-md);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.4;
	}

	.toc-title-icon {
		width: 1em;
		height: 1em;
		stroke-width: 1.8;
		transform: rotate(-18deg) translateY(0.08em);
	}

	ul {
		display: grid;
		gap: 0.95rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		position: relative;
		padding-inline-start: calc(1.25rem + var(--toc-depth) * 1rem);
	}

	li::before {
		position: absolute;
		inset-block-start: 0.72em;
		inset-inline-start: calc(var(--toc-depth) * 1rem);
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 999px;
		background: var(--text-secondary);
		content: '';
	}

	li:has(a.is-active)::before {
		width: 0.52rem;
		height: 0.52rem;
		background: var(--accent-primary);
		box-shadow: 0 0 0 0.22rem color-mix(in srgb, var(--accent-primary) 16%, transparent);
	}

	a {
		display: inline-block;
		color: var(--text-secondary);
		font-size: var(--text-md);
		font-weight: 700;
		text-decoration: none;
		line-height: 1.85;
	}

	a.is-active {
		color: var(--text-primary);
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--accent-primary) 70%, transparent);
		text-decoration-thickness: 0.12em;
		text-underline-offset: 0.28em;
	}

	a:hover {
		color: var(--text-primary);
		text-decoration: underline;
	}

	@media (max-width: 1000px) {
		.article-toc {
			position: static;
			padding: 1rem 1.1rem 1.15rem;
			transform: none;
		}

		ul {
			display: flex;
			flex-wrap: wrap;
			gap: 0.4rem 1rem;
		}
	}
</style>

<script>
	const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
	const tocTargets = tocLinks
		.map((link) => {
			const id = decodeURIComponent(link.hash.slice(1));
			const heading = document.getElementById(id);
			return heading ? { link, heading } : null;
		})
		.filter((item): item is { link: HTMLAnchorElement; heading: HTMLElement } => item !== null);

	const setActiveLink = () => {
		const currentTarget =
			tocTargets.findLast(({ heading }) => heading.getBoundingClientRect().top <= 140) ??
			tocTargets[0];

		for (const { link } of tocTargets) {
			link.classList.toggle('is-active', link === currentTarget?.link);
		}
	};

	setActiveLink();
	window.addEventListener('scroll', setActiveLink, { passive: true });
	window.addEventListener('resize', setActiveLink);
</script>
