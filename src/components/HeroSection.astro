---
import { Image } from 'astro:assets';
import topMainVisual from '../assets/top_mmain_visual.png';
import PageIntro from './PageIntro.astro';

const hero = {
	label: 'About',
	title: '怠惰なりに、\nゆるくしきい低く書く場所',
	date: '2025.04.18',
	cadence: '週1で更新できたらやる',
	tags: ['技術', '内省', '成長', 'sleepy-turtle'],
	body: ['誰かに見せるためというより', '自分の学びとアウトプット習慣をつけるために', '小さな発見と、考えごとの跡を静かに残していく'],
};

const meta = [
	{ icon: 'calendar' as const, text: hero.date },
	{ icon: 'clock' as const, text: hero.cadence },
	{ icon: 'none' as const, text: hero.tags.map((tag) => `#${tag}`).join('　') },
];
---

<PageIntro
	as="section"
	badgeLabel={hero.label}
	title={hero.title}
	titleId="hero-title"
	metaLabel="ブログの基本情報"
	meta={meta}
	lead={hero.body}
>
	<Image
		slot="visual"
		src={topMainVisual}
		alt=""
		width={976}
		height={976}
		loading="eager"
		decoding="async"
	/>
</PageIntro>
