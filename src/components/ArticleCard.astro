---
import CategoryBadge from './CategoryBadge.astro';

interface Article {
	title: string;
	category: string;
	date: string;
	readingTime: string;
	excerpt: string;
	tags: string[];
	href: string;
}

interface Props {
	article: Article;
	featured?: boolean;
}

const { article, featured = false } = Astro.props;

/** 右カラム用: 3行分くらいに収まる目安（全角ベース） */
const SIDE_EXCERPT_MAX = 66;

const displayExcerpt = featured
	? article.excerpt
	: article.excerpt.length > SIDE_EXCERPT_MAX
		? `${article.excerpt.slice(0, SIDE_EXCERPT_MAX)}...`
		: article.excerpt;
const categoryBadgeStyle = `--category-badge-font-size: ${
	featured ? 'var(--text-md)' : 'var(--text-xs)'
}`;
---

<a class:list={['article-card', { featured }]} href={article.href}>
	<div class="article-head">
		<div class="article-category-wrap">
			<CategoryBadge label={article.category} style={categoryBadgeStyle} />
		</div>
		<h3>{article.title}</h3>
		<div class="article-meta">
			<span>{article.date}</span>
			<span>{article.readingTime}</span>
		</div>
	</div>
	<p class:list={[{ 'article-excerpt': !featured }]}>{displayExcerpt}</p>
	<div class="article-footer">
		<span class="article-tags">{article.tags.map((tag) => `#${tag}`).join('　')}</span>
		<span class="read-more">{featured ? '続きを読む' : '→'}</span>
	</div>
</a>

<style>
	.article-card {
		position: relative;
		display: flex;
		min-height: 17.5rem;
		flex-direction: column;
		overflow: hidden;
		padding: 1.65rem 1.65rem 1.35rem 3.8rem;
		border: 1px solid color-mix(in srgb, var(--text-secondary) 22%, transparent);
		border-radius: 2rem 2rem 1.2rem 1.2rem;
		background:
			linear-gradient(90deg, transparent 0 3rem, #e7a24c 3rem calc(3rem + 1px), transparent calc(3rem + 1px)),
			repeating-linear-gradient(
				to bottom,
				transparent 0,
				transparent 2.45rem,
				color-mix(in srgb, var(--border) 18%, transparent) 2.45rem,
				color-mix(in srgb, var(--border) 18%, transparent) calc(2.45rem + 1px)
			),
			var(--surface);
		box-shadow: 0.35rem 0.55rem 0.4rem color-mix(in srgb, var(--border) 32%, transparent);
		color: var(--text-primary);
		text-decoration: none;
	}

	.article-card:hover {
		transform: translateY(-2px);
	}

	.article-card:not(.featured) {
		padding: 1.35rem 1.15rem 1rem 3.45rem;
	}

	.article-card.featured {
		padding: 2.75rem 2.5rem 2.25rem 4.75rem;
		box-shadow: 0.45rem 0.7rem 0.55rem color-mix(in srgb, var(--border) 38%, transparent);
	}

	.article-category-wrap {
		align-self: flex-start;
		margin-block-end: 0.85rem;
	}

	.article-head {
		flex-shrink: 0;
	}

	.article-card:not(.featured) .article-head {
		margin-block-end: 0;
	}

	.article-card:not(.featured) .article-category-wrap {
		margin-block-end: 0.45rem;
	}

	.featured .article-category-wrap {
		margin-block-end: 1.35rem;
	}

	h3 {
		margin: 0;
		max-width: 28rem;
		font-family: var(--font-article-title);
		font-size: clamp(var(--text-lg), 1.25vw, var(--text-xl));
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.35;
	}

	.article-card:not(.featured) h3 {
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		font-size: var(--text-lg);
		line-height: 1.3;
	}

	.featured h3 {
		max-width: 34rem;
		font-size: clamp(var(--text-xl), 2.2vw, var(--text-2xl));
		line-height: 1.4;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem 1.2rem;
		margin-block-start: 1.05rem;
		color: color-mix(in srgb, var(--text-secondary) 78%, transparent);
		font-size: var(--text-xs);
		font-weight: 600;
	}

	.article-card:not(.featured) .article-meta {
		margin-block: 0.5rem 0;
		gap: 0.45rem 0.85rem;
	}

	.featured .article-meta {
		margin-block-start: 1.35rem;
		font-size: var(--text-md);
	}

	.article-meta span + span {
		position: relative;
		padding-inline-start: 1.2rem;
	}

	.article-meta span + span::before {
		position: absolute;
		inset-block: 0.35rem;
		inset-inline-start: 0;
		width: 1px;
		background: color-mix(in srgb, var(--border) 24%, transparent);
		content: '';
	}

	p {
		margin: 1.6rem 0 0;
		color: var(--text-primary);
		font-size: var(--text-sm);
		font-weight: 400;
		line-height: 1.8;
	}

	.article-excerpt {
		flex: 1 1 auto;
		min-height: 0;
		margin-block: 1.15rem 0;
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		line-height: 1.65;
	}

	.featured p {
		flex: 1 1 auto;
		margin-block: 2.75rem 0;
		max-width: 36rem;
		font-size: var(--text-lg);
		line-height: 1.95;
	}

	.article-footer {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-block-start: auto;
		color: color-mix(in srgb, var(--text-secondary) 85%, transparent);
		font-size: var(--text-xs);
		font-weight: 700;
	}

	.article-card:not(.featured) .article-footer {
		flex-shrink: 0;
		gap: 0.5rem;
		margin-block-start: auto;
		padding-block-start: 1rem;
	}

	.article-tags {
		flex: 1 1 auto;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.featured .article-footer {
		padding-block-start: 1.5rem;
		font-size: var(--text-md);
	}

	.read-more {
		flex: 0 0 auto;
		color: var(--text-secondary);
		font-size: var(--text-lg);
	}

	.article-card:not(.featured) .read-more {
		font-size: var(--text-md);
		line-height: 1;
	}

	.featured .read-more {
		font-size: var(--text-xl);
	}

	@media (max-width: 720px) {
		.article-card,
		.article-card.featured {
			min-height: 0;
			height: auto;
			padding: 1.4rem 1.2rem 1.2rem 3.55rem;
			border-radius: 1.5rem 1.5rem 1rem 1rem;
			box-shadow: 0.35rem 0.55rem 0.4rem color-mix(in srgb, var(--border) 32%, transparent);
		}

		.featured p {
			flex: none;
			margin-block-start: 2rem;
			max-width: none;
		}

		.featured .article-footer {
			padding-block-start: 0;
		}

		.featured h3 {
			font-size: clamp(var(--text-xl), 7vw, var(--text-2xl));
		}
	}
</style>
