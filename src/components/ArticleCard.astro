---
interface Article {
	title: string;
	category: string;
	date: string;
	readingTime: string;
	excerpt: string;
	tags: string[];
	href: string;
}

interface Props {
	article: Article;
	featured?: boolean;
}

const { article, featured = false } = Astro.props;
---

<a class:list={['article-card', { featured }]} href={article.href}>
	<span class="article-category">{article.category}</span>
	<h3>{article.title}</h3>
	<div class="article-meta">
		<span>{article.date}</span>
		<span>{article.readingTime}</span>
	</div>
	<p>{article.excerpt}</p>
	<div class="article-footer">
		<span>{article.tags.map((tag) => `#${tag}`).join('　')}</span>
		<span class="read-more">{featured ? '続きを読む' : '→'}</span>
	</div>
</a>

<style>
	.article-card {
		position: relative;
		display: flex;
		min-height: 17.5rem;
		flex-direction: column;
		overflow: hidden;
		padding: 1.65rem 1.65rem 1.35rem 3.8rem;
		border: 1px solid color-mix(in srgb, var(--text-secondary) 22%, transparent);
		border-radius: 2rem 2rem 1.2rem 1.2rem;
		background:
			linear-gradient(90deg, transparent 0 3rem, #e7a24c 3rem calc(3rem + 1px), transparent calc(3rem + 1px)),
			repeating-linear-gradient(
				to bottom,
				transparent 0,
				transparent 2.45rem,
				color-mix(in srgb, var(--border) 18%, transparent) 2.45rem,
				color-mix(in srgb, var(--border) 18%, transparent) calc(2.45rem + 1px)
			),
			var(--surface);
		box-shadow: 0.35rem 0.55rem 0.4rem color-mix(in srgb, var(--border) 32%, transparent);
		color: var(--text-primary);
		text-decoration: none;
	}

	.article-card:hover {
		transform: translateY(-2px);
	}

	.article-card.featured {
		min-height: 29rem;
		padding: 2rem 2rem 1.6rem 4.25rem;
	}

	.article-category {
		align-self: flex-start;
		margin-block-end: 1.35rem;
		padding: 0.25rem 0.8rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--text-secondary) 24%, transparent);
		color: var(--text-secondary);
		font-size: var(--text-xs);
		font-weight: 800;
		line-height: 1;
	}

	h3 {
		margin: 0;
		max-width: 28rem;
		font-family: var(--font-article-title);
		font-size: clamp(var(--text-lg), 1.25vw, var(--text-xl));
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.35;
	}

	.featured h3 {
		font-size: clamp(var(--text-2xl), 2.7vw, var(--text-3xl));
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem 1.2rem;
		margin-block-start: 1.05rem;
		color: color-mix(in srgb, var(--text-secondary) 78%, transparent);
		font-size: var(--text-xs);
		font-weight: 600;
	}

	.featured .article-meta {
		font-size: var(--text-md);
	}

	.article-meta span + span {
		position: relative;
		padding-inline-start: 1.2rem;
	}

	.article-meta span + span::before {
		position: absolute;
		inset-block: 0.35rem;
		inset-inline-start: 0;
		width: 1px;
		background: color-mix(in srgb, var(--border) 24%, transparent);
		content: '';
	}

	p {
		margin: 1.6rem 0 0;
		color: var(--text-primary);
		font-size: var(--text-sm);
		font-weight: 600;
		line-height: 1.8;
	}

	.featured p {
		margin-block-start: 2.3rem;
		font-size: var(--text-lg);
		line-height: 2;
	}

	.article-footer {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-block-start: auto;
		color: color-mix(in srgb, var(--text-secondary) 85%, transparent);
		font-size: var(--text-xs);
		font-weight: 700;
	}

	.featured .article-footer {
		font-size: var(--text-md);
	}

	.read-more {
		flex: 0 0 auto;
		color: var(--text-secondary);
		font-size: var(--text-lg);
	}

	.featured .read-more {
		font-size: var(--text-xl);
	}

	@media (max-width: 720px) {
		.article-card,
		.article-card.featured {
			min-height: 0;
			padding: 1.4rem 1.2rem 1.2rem 3.55rem;
			border-radius: 1.5rem 1.5rem 1rem 1rem;
		}

		.featured h3 {
			font-size: clamp(var(--text-xl), 8vw, calc(var(--text-2xl) * 1.12));
		}
	}
</style>
