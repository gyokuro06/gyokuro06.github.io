---
import HeroSection from '../components/HeroSection.astro';
import Layout from '../layouts/Layout.astro';
import MainSection from '../components/MainSection.astro';

const articles = [
	{
		title: '怠惰な人間なりに、少しずつ成長するためのログ',
		category: '考え事',
		date: '2025.04.18',
		readingTime: 'だいたい6分くらい',
		excerpt:
			'夜の静けさのなかでコードを書いていると、昼間には気づかなかった小さな違和感や、見過ごしていた設計のほころびに気づくことがあります。',
		tags: ['設計', '内省', 'TypeScript'],
		href: '/posts/sleepy-turtle-log',
	},
];
---

<Layout title="sleepy-turtle">
	<div class="hero-section-container">
		<HeroSection />
	</div>
	<MainSection articles={articles} />
</Layout>

<style>
	.hero-section-container {
		margin-block-end: 46px;
		overflow: visible;
	}
</style>
