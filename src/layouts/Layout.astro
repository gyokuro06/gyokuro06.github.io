---
import Header from '../components/Header.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'sleepy-turtle',
	description = '森の中の作業机から届ける個人ブログ',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Klee+One:wght@400;600&family=Zen+Kurenaido&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />

		<main class="site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<p>Notes from a quiet desk.</p>
		</footer>
	</body>
</html>

<style>
	:root {
		--background: #f2f5ea;
		--surface: #f5f7ef;
		--border: #83847e;
		--text-primary: #1c281e;
		--text-secondary: #4f6f52;
		--button-primary-background: #4f6f52;
		--button-primary-background-hover: #768f78;
		--button-primary-text: #f2f5ea;
		--font-body: 'Zen Maru Gothic', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
		--font-display: 'Zen Kurenaido', serif;
		--font-quote: 'Klee One', cursive;
		--font-code: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
			'Liberation Mono', 'Courier New', monospace;
		--font-site-title: var(--font-display);
		--font-heading-1: var(--font-display);
		--font-article-title: var(--font-display);
		--font-article-body: var(--font-body);
		--font-quote-text: var(--font-quote);
		--font-meta: var(--font-body);
		font-family: var(--font-body);
		color: var(--text-primary);
		background: var(--background);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		min-height: 100vh;
		background: var(--background);
		color: var(--text-primary);
		line-height: 1.75;
	}

	a {
		color: inherit;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.25em;
	}

	.site-main,
	.site-footer {
		width: min(100% - 2rem, 960px);
		margin-inline: auto;
	}

	.site-main {
		padding-block: 4rem 5rem;
	}

	.site-footer {
		border-top: 1px solid color-mix(in srgb, var(--border) 35%, transparent);
		color: var(--text-secondary);
		font-size: 0.9rem;
		padding-block: 1.5rem 2rem;
	}

	.site-footer p {
		margin: 0;
	}

</style>
